generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model account_movements {
  id             BigInt                          @id @default(autoincrement())
  account_id     BigInt
  operation_id   BigInt
  movement_type  account_movements_movement_type
  amount         Decimal                         @db.Decimal(18, 2)
  currency       account_movements_currency
  balance_before Decimal?                        @db.Decimal(18, 2)
  balance_after  Decimal?                        @db.Decimal(18, 2)
  description    String?                         @db.Text
  created_at     DateTime                        @default(now()) @db.Timestamp(0)
  accounts       accounts                        @relation(fields: [account_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_movements_account")
  operations     operations                      @relation(fields: [operation_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_movements_operation")

  @@index([operation_id], map: "fk_movements_operation")
  @@index([account_id], map: "idx_movements_account")
}

model accounts {
  id                                                                     BigInt                          @id @default(autoincrement())
  name                                                                   String                          @db.VarChar(190)
  account_type                                                           accounts_account_type
  currency                                                               accounts_currency
  initial_balance                                                        Decimal?                        @default(0.00) @db.Decimal(18, 2)
  current_balance                                                        Decimal?                        @default(0.00) @db.Decimal(18, 2)
  min_threshold                                                          Decimal                         @default(0.00) @db.Decimal(18, 2)
  account_number                                                         String?                         @db.VarChar(190)
  description                                                            String?                         @db.Text
  is_active                                                              Boolean?                        @default(true)
  created_at                                                             DateTime                        @default(now()) @db.Timestamp(0)
  updated_at                                                             DateTime                        @default(now()) @db.Timestamp(0)
  deleted_at                                                             DateTime?                       @db.DateTime(0)
  account_movements                                                      account_movements[]
  expenses                                                               expenses[]
  internal_transfers_internal_transfers_destination_account_idToaccounts internal_transfers[]            @relation("internal_transfers_destination_account_idToaccounts")
  internal_transfers_internal_transfers_source_account_idToaccounts      internal_transfers[]            @relation("internal_transfers_source_account_idToaccounts")
  operations_operations_destination_account_idToaccounts                 operations[]                    @relation("operations_destination_account_idToaccounts")
  operations_operations_source_account_idToaccounts                      operations[]                    @relation("operations_source_account_idToaccounts")
  payments                                                               payments[]
  product_account_compatibility                                          product_account_compatibility[]
  user_accounts                                                          user_accounts[]

  @@index([currency], map: "idx_accounts_currency")
}

model audit_logs {
  id          BigInt   @id @default(autoincrement())
  user_id     BigInt?
  action      String   @db.VarChar(190)
  entity_type String   @db.VarChar(190)
  entity_id   BigInt?
  old_values  String?  @db.LongText
  new_values  String?  @db.LongText
  ip_address  String?  @db.VarChar(100)
  user_agent  String?  @db.Text
  created_at  DateTime @default(now()) @db.Timestamp(0)
  users       users?   @relation(fields: [user_id], references: [id], onUpdate: NoAction, map: "fk_audit_user")

  @@index([user_id], map: "fk_audit_user")
  @@index([entity_type, entity_id], map: "idx_audit_entity")
}

model clients {
  id               BigInt               @id @default(autoincrement())
  full_name        String               @db.VarChar(190)
  phone            String?              @db.VarChar(30)
  email            String?              @db.VarChar(190)
  address          String?              @db.Text
  client_type      clients_client_type? @default(NORMAL)
  classification   String               @default("NORMAL") @db.VarChar(50)
  credit_limit     Decimal              @default(0.00) @db.Decimal(18, 2)
  email_opt_in     Boolean              @default(true)
  notes            String?              @db.Text
  total_operations Int?                 @default(0)
  total_profit     Decimal?             @default(0.00) @db.Decimal(18, 2)
  created_at       DateTime             @default(now()) @db.Timestamp(0)
  updated_at       DateTime             @default(now()) @db.Timestamp(0)
  deleted_at       DateTime?            @db.DateTime(0)
  invoices         invoices[]
  operations       operations[]
}

model exchange_rates {
  id                 BigInt                         @id @default(autoincrement())
  base_currency      exchange_rates_base_currency
  target_currency    exchange_rates_target_currency
  rate               Decimal                        @db.Decimal(18, 6)
  created_by_user_id BigInt?
  created_at         DateTime                       @default(now()) @db.Timestamp(0)
  users              users?                         @relation(fields: [created_by_user_id], references: [id], onUpdate: NoAction, map: "fk_exchange_rate_user")

  @@index([created_by_user_id], map: "fk_exchange_rate_user")
}

model expenses {
  id                 BigInt            @id @default(autoincrement())
  category           String            @db.VarChar(190)
  account_id         BigInt
  amount             Decimal           @db.Decimal(18, 2)
  currency           expenses_currency
  description        String?           @db.Text
  expense_date       DateTime          @db.DateTime(0)
  receipt_file       String?           @db.VarChar(255)
  created_by_user_id BigInt
  created_at         DateTime          @default(now()) @db.Timestamp(0)
  deleted_at         DateTime?         @db.DateTime(0)
  accounts           accounts          @relation(fields: [account_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_expenses_account")
  users              users             @relation(fields: [created_by_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_expenses_user")

  @@index([account_id], map: "fk_expenses_account")
  @@index([created_by_user_id], map: "fk_expenses_user")
}

model internal_transfers {
  id                                                           BigInt   @id @default(autoincrement())
  source_account_id                                            BigInt
  destination_account_id                                       BigInt
  source_amount                                                Decimal  @db.Decimal(18, 2)
  destination_amount                                           Decimal  @db.Decimal(18, 2)
  exchange_rate                                                Decimal? @db.Decimal(18, 6)
  notes                                                        String?  @db.Text
  transfer_date                                                DateTime @db.DateTime(0)
  created_by_user_id                                           BigInt
  created_at                                                   DateTime @default(now()) @db.Timestamp(0)
  accounts_internal_transfers_destination_account_idToaccounts accounts @relation("internal_transfers_destination_account_idToaccounts", fields: [destination_account_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_transfer_destination_account")
  accounts_internal_transfers_source_account_idToaccounts      accounts @relation("internal_transfers_source_account_idToaccounts", fields: [source_account_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_transfer_source_account")
  users                                                        users    @relation(fields: [created_by_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_transfer_user")

  @@index([destination_account_id], map: "fk_transfer_destination_account")
  @@index([source_account_id], map: "fk_transfer_source_account")
  @@index([created_by_user_id], map: "fk_transfer_user")
}

model invoices {
  id               BigInt                   @id @default(autoincrement())
  invoice_number   String                   @unique(map: "invoice_number") @db.VarChar(100)
  client_id        BigInt
  total_amount     Decimal                  @db.Decimal(18, 2)
  paid_amount      Decimal?                 @default(0.00) @db.Decimal(18, 2)
  remaining_amount Decimal?                 @default(0.00) @db.Decimal(18, 2)
  currency         invoices_currency?       @default(DZD)
  status           invoices_status?         @default(UNPAID)
  payment_method   payments_payment_method?
  due_date         DateTime?                @db.Date
  notes            String?                  @db.Text
  created_at       DateTime                 @default(now()) @db.Timestamp(0)
  updated_at       DateTime                 @default(now()) @db.Timestamp(0)
  deleted_at       DateTime?                @db.DateTime(0)
  sent_at          DateTime?                @db.DateTime(0)
  clients          clients                  @relation(fields: [client_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_invoices_client")
  operations       operations[]
  payments         payments[]
  invoice_items    invoice_items[]

  @@index([client_id], map: "fk_invoices_client")
  @@index([status], map: "idx_invoices_status")
}

model invoice_items {
  id           BigInt     @id @default(autoincrement())
  invoice_id   BigInt
  operation_id BigInt
  description  String?    @db.Text
  quantity     Decimal    @db.Decimal(18, 2)
  unit_price   Decimal    @db.Decimal(18, 2)
  total        Decimal    @db.Decimal(18, 2)
  created_at   DateTime   @default(now()) @db.Timestamp(0)
  invoices     invoices   @relation(fields: [invoice_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_invoice_items_invoice")
  operations   operations @relation(fields: [operation_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_invoice_items_operation")

  @@index([invoice_id], map: "fk_invoice_items_invoice")
  @@index([operation_id], map: "fk_invoice_items_operation")
}

model operations {
  id                                                   BigInt                       @id @default(autoincrement())
  operation_type                                       operations_operation_type
  product_id                                           BigInt
  client_id                                            BigInt?
  source_account_id                                    BigInt?
  destination_account_id                               BigInt?
  created_by_user_id                                   BigInt
  validated_by_user_id                                 BigInt?
  amount_dzd                                           Decimal?                     @default(0.00) @db.Decimal(18, 2)
  foreign_amount                                       Decimal?                     @default(0.00) @db.Decimal(18, 2)
  foreign_currency                                     operations_foreign_currency?
  exchange_rate                                        Decimal?                     @db.Decimal(18, 6)
  operation_cost                                       Decimal?                     @default(0.00) @db.Decimal(18, 2)
  profit                                               Decimal?                     @default(0.00) @db.Decimal(18, 2)
  status                                               operations_status?           @default(COMPLETED)
  notes                                                String?                      @db.Text
  attachment_url                                       String?                      @db.Text
  operation_date                                       DateTime                     @db.DateTime(0)
  created_at                                           DateTime                     @default(now()) @db.Timestamp(0)
  updated_at                                           DateTime                     @default(now()) @db.Timestamp(0)
  deleted_at                                           DateTime?                    @db.DateTime(0)
  invoice_id                                           BigInt?
  invoiced                                             Boolean                      @default(false)
  account_movements                                    account_movements[]
  invoices                                             invoices?                    @relation(fields: [invoice_id], references: [id], onUpdate: NoAction, map: "fk_operations_invoice")
  clients                                              clients?                     @relation(fields: [client_id], references: [id], onUpdate: NoAction, map: "fk_operations_client")
  users_operations_created_by_user_idTousers           users                        @relation("operations_created_by_user_idTousers", fields: [created_by_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_operations_created_by")
  accounts_operations_destination_account_idToaccounts accounts?                    @relation("operations_destination_account_idToaccounts", fields: [destination_account_id], references: [id], onUpdate: NoAction, map: "fk_operations_destination_account")
  products                                             products                     @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_operations_product")
  accounts_operations_source_account_idToaccounts      accounts?                    @relation("operations_source_account_idToaccounts", fields: [source_account_id], references: [id], onUpdate: NoAction, map: "fk_operations_source_account")
  users_operations_validated_by_user_idTousers         users?                       @relation("operations_validated_by_user_idTousers", fields: [validated_by_user_id], references: [id], onUpdate: NoAction, map: "fk_operations_validated_by")
  operation_files                                      operation_files[]
  invoice_items                                        invoice_items[]

  @@index([created_by_user_id], map: "fk_operations_created_by")
  @@index([destination_account_id], map: "fk_operations_destination_account")
  @@index([product_id], map: "fk_operations_product")
  @@index([source_account_id], map: "fk_operations_source_account")
  @@index([validated_by_user_id], map: "fk_operations_validated_by")
  @@index([client_id], map: "idx_operations_client")
  @@index([operation_date], map: "idx_operations_date")
  @@index([invoice_id], map: "fk_operations_invoice")
}

model operation_files {
  id           BigInt     @id @default(autoincrement())
  operation_id BigInt
  filename     String     @db.VarChar(190)
  path         String     @db.Text
  mime_type    String     @db.VarChar(100)
  size         Int
  created_at   DateTime   @default(now()) @db.Timestamp(0)
  operations   operations @relation(fields: [operation_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_operation_files_operation")

  @@index([operation_id], map: "fk_operation_files_operation")
}

model payments {
  id                 BigInt                  @id @default(autoincrement())
  invoice_id         BigInt
  account_id         BigInt
  amount             Decimal                 @db.Decimal(18, 2)
  currency           payments_currency
  payment_method     payments_payment_method
  reference_number   String?                 @db.VarChar(190)
  notes              String?                 @db.Text
  payment_date       DateTime                @db.DateTime(0)
  created_by_user_id BigInt
  created_at         DateTime                @default(now()) @db.Timestamp(0)
  deleted_at         DateTime?               @db.DateTime(0)
  accounts           accounts                @relation(fields: [account_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_payments_account")
  users              users                   @relation(fields: [created_by_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_payments_created_by")
  invoices           invoices                @relation(fields: [invoice_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_payments_invoice")

  @@index([account_id], map: "fk_payments_account")
  @@index([created_by_user_id], map: "fk_payments_created_by")
  @@index([invoice_id], map: "fk_payments_invoice")
  @@index([payment_date], map: "idx_payments_date")
}

model product_account_compatibility {
  id                 BigInt                     @id @default(autoincrement())
  product_id         BigInt
  account_id         BigInt
  compatibility_type product_compatibility_type @default(BOTH)
  created_at         DateTime                   @default(now()) @db.Timestamp(0)
  accounts           accounts                   @relation(fields: [account_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_product_compatibility_account")
  products           products                   @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_product_compatibility_product")

  @@index([account_id], map: "fk_product_compatibility_account")
  @@index([product_id], map: "fk_product_compatibility_product")
}

model products {
  id                            BigInt                          @id @default(autoincrement())
  name                          String                          @unique(map: "name") @db.VarChar(190)
  category                      products_category
  description                   String?                         @db.Text
  buy_price                     Decimal                         @default(0.00) @db.Decimal(18, 2)
  sell_price                    Decimal                         @default(0.00) @db.Decimal(18, 2)
  is_active                     Boolean?                        @default(true)
  created_at                    DateTime                        @default(now()) @db.Timestamp(0)
  deleted_at                    DateTime?                       @db.DateTime(0)
  operations                    operations[]
  product_account_compatibility product_account_compatibility[]
}

model user_accounts {
  id               BigInt                          @id @default(autoincrement())
  user_id          BigInt
  account_id       BigInt
  permission_level user_accounts_permission_level? @default(VIEWER)
  created_at       DateTime                        @default(now()) @db.Timestamp(0)
  accounts         accounts                        @relation(fields: [account_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user_accounts_account")
  users            users                           @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user_accounts_user")

  @@index([account_id], map: "fk_user_accounts_account")
  @@index([user_id], map: "fk_user_accounts_user")
}

model users {
  id                                                BigInt               @id @default(autoincrement())
  keycloak_user_id                                  String?              @unique(map: "keycloak_user_id") @db.VarChar(190)
  local_password                                    String?              @db.VarChar(255)
  role                                              String               @default("EMPLOYEE") @db.VarChar(50)
  force_password_change                             Boolean              @default(false)
  login_attempts                                    Int                  @default(0)
  locked_until                                      DateTime?            @db.DateTime(0)
  last_login                                        DateTime?            @db.DateTime(0)
  full_name                                         String               @db.VarChar(190)
  email                                             String               @unique(map: "email") @db.VarChar(190)
  phone                                             String?              @db.VarChar(30)
  is_active                                         Boolean?             @default(true)
  created_at                                        DateTime             @default(now()) @db.Timestamp(0)
  updated_at                                        DateTime             @default(now()) @db.Timestamp(0)
  audit_logs                                        audit_logs[]
  exchange_rates                                    exchange_rates[]
  expenses                                          expenses[]
  internal_transfers                                internal_transfers[]
  operations_operations_created_by_user_idTousers   operations[]         @relation("operations_created_by_user_idTousers")
  operations_operations_validated_by_user_idTousers operations[]         @relation("operations_validated_by_user_idTousers")
  payments                                          payments[]
  user_accounts                                     user_accounts[]
  alert_dismissals                                  alert_dismissals[]
  settings                                          settings[]

  @@index([email], map: "idx_users_email")
}

model meta_ads_accounts {
  id                  BigInt                @id @default(autoincrement())
  name                String                @db.VarChar(190)
  platform            String                @db.VarChar(50)
  initial_credit      Decimal               @db.Decimal(18, 2)
  currency            String                @db.VarChar(10)
  due_date            DateTime              @db.Date
  is_active           Boolean               @default(true)
  created_at          DateTime              @default(now()) @db.Timestamp(0)
  updated_at          DateTime              @default(now()) @db.Timestamp(0)
  meta_ads_deductions meta_ads_deductions[]
}

model meta_ads_deductions {
  id                BigInt            @id @default(autoincrement())
  account_id        BigInt
  amount            Decimal           @db.Decimal(18, 2)
  deduction_date    DateTime          @db.DateTime(0)
  description       String?           @db.Text
  invoice_ref       String?           @db.VarChar(190)
  created_at        DateTime          @default(now()) @db.Timestamp(0)
  meta_ads_accounts meta_ads_accounts @relation(fields: [account_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_deductions_account")

  @@index([account_id], map: "fk_deductions_account")
}

model alerts {
  id               BigInt             @id @default(autoincrement())
  type             String             @db.VarChar(100)
  severity         String             @db.VarChar(50)
  message          String             @db.Text
  entity_type      String?            @db.VarChar(100)
  entity_id        BigInt?
  is_resolved      Boolean            @default(false)
  resolved_at      DateTime?          @db.DateTime(0)
  created_at       DateTime           @default(now()) @db.Timestamp(0)
  alert_dismissals alert_dismissals[]
}

model alert_dismissals {
  id           BigInt   @id @default(autoincrement())
  alert_id     BigInt
  user_id      BigInt
  dismissed_at DateTime @default(now()) @db.Timestamp(0)
  alerts       alerts   @relation(fields: [alert_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_dismissals_alert")
  users        users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_dismissals_user")

  @@index([alert_id], map: "fk_dismissals_alert")
  @@index([user_id], map: "fk_dismissals_user")
}

model settings {
  id                 BigInt   @id @default(autoincrement())
  key_name           String   @unique(map: "key_name") @db.VarChar(190)
  value_data         String?  @db.LongText
  updated_by_user_id BigInt?
  updated_at         DateTime @default(now()) @db.Timestamp(0)
  users              users?   @relation(fields: [updated_by_user_id], references: [id], onUpdate: NoAction, map: "fk_settings_user")

  @@index([updated_by_user_id], map: "fk_settings_user")
}

enum product_compatibility_type {
  SOURCE
  DESTINATION
  BOTH
}

enum exchange_rates_base_currency {
  DZD
  USD
  EUR
  USDT
}

enum operations_operation_type {
  SALE
  PURCHASE
  TRANSFER
  EXPENSE
  PAYMENT
}

enum accounts_account_type {
  CASH
  CCP
  PAYONEER
  PAYPAL
  REDOTPAY
  BANK
  ADS
}

enum exchange_rates_target_currency {
  DZD
  USD
  EUR
  USDT
}

enum products_category {
  TIKTOK_COINS
  BUY_TIKTOK_USD
  SELL_USDT
  BUY_USDT
  ADS_META
  SERVICE
}

enum account_movements_movement_type {
  IN
  OUT
}

enum accounts_currency {
  DZD
  USD
  EUR
  USDT
}

enum user_accounts_permission_level {
  OWNER
  MANAGER
  ACCOUNTANT
  VIEWER
}

enum expenses_currency {
  DZD
  USD
  EUR
  USDT
}

enum payments_currency {
  DZD
  USD
  EUR
  USDT
}

enum account_movements_currency {
  DZD
  USD
  EUR
  USDT
}

enum clients_client_type {
  NORMAL
  VIP
  RISK
}

enum payments_payment_method {
  CASH
  CCP
  PAYONEER
  PAYPAL
  REDOTPAY
  BANK_TRANSFER
  CRYPTO
}

enum invoices_currency {
  DZD
  USD
  EUR
  USDT
}

enum invoices_status {
  DRAFT
  UNPAID
  PARTIAL
  PAID
  OVERDUE
}

enum operations_foreign_currency {
  USD
  EUR
  USDT
}

enum operations_status {
  PENDING
  COMPLETED
  CANCELLED
}
